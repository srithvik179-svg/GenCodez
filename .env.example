# ========================================
# TrustVote Environment Variables
# Copy this to .env and fill in your values
# ========================================

# ---------- Server ----------
PORT=5000
NODE_ENV=development

# ---------- MongoDB ----------
MONGODB_URI=mongodb://localhost:27017/trustvote

# ---------- JWT (for email/password auth) ----------
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=7d

# ---------- Blockchain ----------
# Use Hardhat local by default; switch to Polygon testnet for staging
RPC_URL=http://127.0.0.1:8545
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
CONTRACT_ADDRESS=

# Polygon Amoy Testnet (uncomment when ready)
# RPC_URL=https://rpc-amoy.polygon.technology
# PRIVATE_KEY=your_wallet_private_key

# ---------- Frontend ----------
VITE_API_URL=http://localhost:5000/api
VITE_CONTRACT_ADDRESS=
