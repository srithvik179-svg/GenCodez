{
  "name": "trustvote",
  "version": "1.0.0",
  "description": "TrustVote — Secure Blockchain Voting System powered by Polygon",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "contracts"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev:contracts": "npm run compile --workspace=contracts",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "npm run build --workspace=client",
    "test:contracts": "npm run test --workspace=contracts",
    "install:all": "npm install"
  },
  "keywords": ["blockchain", "voting", "polygon", "solidity", "react"],
  "author": "TrustVote Team",
  "license": "MIT"
}
